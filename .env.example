# LLM Provider Configuration
# Copy this file to .env and fill in your API key

# Choose provider: opengauss, grok, openai, anthropic, or mock
# If not set, will auto-detect based on available tools/API keys
LLM_PROVIDER=grok

# API Keys (set the one for your chosen provider)
XAI_API_KEY=your-xai-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenGauss Configuration (optional)
# Set this if you want to use OpenGauss for formalization
# OPENGAUSS_PROJECT_PATH=/path/to/your/lean/project
# Or create .gauss/project.yaml in your project directory

# Model selection (optional - defaults will be used if not set)
# For OpenGauss: gauss-autoformalize, gauss-prove
# For Grok: grok-3, grok-2-latest
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# For Anthropic: claude-3-opus, claude-3-sonnet
LLM_MODEL=grok-3
